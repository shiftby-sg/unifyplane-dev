{
  "plan_name": "unifyplane_dev_website_implementation_plan",
  "version": "2.1.0",
  "project": "unifyplane.dev",
  "implementation_type": "Next.js static-first canonical-docs-driven website",
  "canonical_docs_root_reference": "/home/manandakrishna/myprojects/unifyplane/unifyplane-dev/docs/canonical",
  "primary_canonical_doc_reference": "/home/manandakrishna/myprojects/unifyplane/unifyplane-dev/docs/canonical/website-information-architecture.v2.md",
  "canonical_docs_rule": "All canonical markdown documents under docs/canonical are reference-only source-of-truth inputs. They must be copied or derived into the repo content folders during implementation. UI, routes, metadata, page templates, and design behavior must derive from them and must not redefine canonical meaning.",
  "repo_content_root": "/home/manandakrishna/myprojects/unifyplane/unifyplane-dev/content",
  "governing_specs": {
    "required_contract_specs": [
      {
        "path": "contracts/specs/unfiplane.page.seo.spec.json",
        "role": "authoritative page-wise SEO, metadata, canonical URL, JSON-LD, breadcrumb, and indexing contract"
      },
      {
        "path": "contracts/specs/unifyplane.design.spec.json",
        "role": "authoritative design system, tokens, layout, typography, boundary semantics, accessibility, responsive behavior, and component-state contract"
      }
    ],
    "enforcement_rule": "Implementation must validate against these contract specs in every relevant phase. Missing or contradictory implementation fails closed."
  },
  "content_governance_model": {
    "content_classes": {
      "canonical": "Reference truth documents copied from docs/canonical into /content/core and never casually rewritten to suit page needs.",
      "publishable": "Public-facing pages in /content/pages, /content/components, and /content/foundations derived from canonical sources.",
      "composed": "Assembly/config artifacts in /content/compositions used for homepage, navigation, page-map, and related-linking. Composed files may arrange content but should own minimal prose."
    },
    "repo_content_structure": [
      "/content/core",
      "/content/pages",
      "/content/components",
      "/content/foundations",
      "/content/compositions"
    ],
    "copy_rule": "Phase 1 must copy or normalize canonical docs from docs/canonical into /content/core before any page implementation proceeds.",
    "publishable_rule": "Publishable pages must declare truthSource and derivedFrom mappings to copied /content/core documents.",
    "homepage_rule": "Homepage content is composition-driven. It must not become an independent truth source and must be assembled from canonical excerpts, curated summaries, and registry-driven route blocks."
  },
  "governing_chain": {
    "ia_chain": [
      "practical problem recognition",
      "plain-language definition",
      "current readiness",
      "evidence",
      "operational parts",
      "deeper foundations"
    ],
    "reader_flow": [
      "problem",
      "definition",
      "current truth",
      "evidence",
      "operational reality",
      "deeper understanding"
    ]
  },
  "global_execution_rules": {
    "G0_1_fail_closed_phase_progression": {
      "rule": "Any failed phase validation halts the plan. No continuation to next phase until fix is applied and approval is recorded."
    },
    "G0_2_canonical_content_priority": {
      "rule": "Canonical markdown documents are the only source of content truth. Implementation must never outrun or contradict canonical documents."
    },
    "G0_3_static_first_delivery": {
      "rule": "Default to static generation and Server Components. Client Components allowed only for necessary interaction islands."
    },
    "G0_4_performance_budget_required": {
      "rule": "Every phase must preserve text-first rendering, low JavaScript cost, and mobile-first performance."
    },
    "G0_5_phase_validation_mandatory": {
      "required_outputs": [
        "output_artifact",
        "validation_result",
        "test_case_result",
        "missing_md_report"
      ]
    },
    "G0_6_human_approval_gate": {
      "rule": "After each phase, evidence must be reviewed and approved manually before the next phase begins."
    },
    "G0_7_mobile_first_and_seo_first": {
      "rule": "All routes, layouts, templates, metadata, and page rendering must be mobile optimized, indexable, and semantically structured from the first implementation pass."
    },
    "G0_8_registry_driven_public_routing": {
      "rule": "Dynamic public routes must be generated only from approved registries. Markdown file presence alone must not create a public route."
    },
    "G0_9_truth_source_enforcement": {
      "rule": "Every indexable publishable page must declare truthSource and derivedFrom mappings. Missing truthSource fails validation."
    },
    "G0_10_missing_markdown_visibility": {
      "rule": "Every phase must explicitly report missing required .md files for that phase. Missing docs block phase completion unless the phase explicitly allows scaffold-only creation."
    },
    "G0_11_contract_spec_enforcement": {
      "rule": "All implementation affecting SEO, metadata, JSON-LD, layout, typography, accessibility, component behavior, navigation, or responsive behavior must conform to the required contract specs under contracts/specs."
    },
    "G0_12_design_spec_is_single_design_authority": {
      "rule": "contracts/specs/unifyplane.design.spec.json is the only implementation design authority. Older design-style documents must not be used as competing implementation guidance."
    },
    "G0_13_seo_spec_is_single_seo_authority": {
      "rule": "contracts/specs/unfiplane.page.seo.spec.json is the only implementation SEO authority for metadata, canonicals, breadcrumbs, JSON-LD, and indexing behavior."
    }
  },
  "performance_targets": {
    "hero_signal_time": "<3 seconds perceived recognition",
    "home_page_section_signal_time": "<10 seconds perceived comprehension",
    "foundation_page_read_time": "<2 minutes first-pass comprehension",
    "core_web_vitals_targets": {
      "LCP": "low LCP target with immediate text-first rendering",
      "INP": "low INP target with minimal client-side interaction cost",
      "CLS": "near-zero layout shift target"
    },
    "delivery_constraints": [
      "minimal client JavaScript",
      "Server Components by default",
      "static generation for all canonical pages",
      "self-hosted optimized fonts",
      "optimized images only where necessary",
      "no heavy animation or carousel above the fold",
      "no client-side markdown rendering"
    ]
  },
  "audience_model": {
    "primary_audience": [
      "enterprise architecture and architecture-governance readers",
      "assurance, audit, and control-oriented technical readers",
      "security assurance and security architecture readers",
      "senior engineering, platform, and technical-governance readers"
    ],
    "secondary_audience_handling": [
      "serve through supporting content where relevant",
      "use Writing for broader audience reach",
      "do not allow secondary audiences to dominate navigation or first-contact language"
    ],
    "ux_principles": [
      "problem signal first",
      "trust boundary visible",
      "evidence before expansion",
      "one page one job",
      "serious documentation feel rather than product marketing"
    ]
  },
  "seo_and_indexing_model": {
    "page_intent_rule": "Each route must own one primary search and reading intent.",
    "metadata_requirements": [
      "unique title",
      "unique description",
      "canonical URL",
      "Open Graph metadata",
      "structured heading hierarchy",
      "page-wise JSON-LD appropriate to page type",
      "BreadcrumbList on non-home indexable routes"
    ],
    "internal_linking_model": [
      "link pages according to governing chain",
      "avoid duplication drift",
      "preserve canonical source ownership",
      "cluster narrative, operational, and foundation pages semantically"
    ],
    "indexing_priority_routes": [
      "/",
      "/what-is-unifyplane",
      "/why-it-matters",
      "/current-readiness",
      "/evidence",
      "/components",
      "/foundations"
    ],
    "seo_delivery_rule": "Metadata and JSON-LD are implemented during page phases, then audited in the final release phase."
  },
