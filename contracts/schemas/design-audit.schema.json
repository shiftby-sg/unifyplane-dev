{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "unifyplane.design.audit.schema.json",
  "title": "UnifyPlane Design Audit Spec Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specVersion",
    "name",
    "authoritativeDesignSpec",
    "globalRules",
    "classifications",
    "requiredFailureArtifacts",
    "requiredSuccessArtifacts",
    "phases"
  ],
  "properties": {
    "specVersion": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "const": "unifyplane.design.audit" },
    "authoritativeDesignSpec": { "type": "string", "minLength": 1 },
    "globalRules": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "rules"],
        "properties": {
          "id": { "type": "string", "pattern": "^G0\\.[1-6]$" },
          "title": { "type": "string", "minLength": 1 },
          "rules": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "classifications": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "type": "string", "enum": ["APPLIED", "PARTIAL", "MISSING", "CONFLICT"] },
      "uniqueItems": true
    },
    "requiredFailureArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "requiredSuccessArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "phases": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "objective",
          "approvalRequired",
          "outputs",
          "checks",
          "validation",
          "failureConditions",
          "requiredArtifacts"
        ],
        "properties": {
          "id": { "type": "integer", "minimum": 1, "maximum": 11 },
          "name": { "type": "string", "minLength": 1 },
          "objective": { "type": "string", "minLength": 1 },
          "approvalRequired": { "type": "boolean" },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "checks": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "validation": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "failureConditions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "requiredArtifacts": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        }
      }
    }
  }
}

